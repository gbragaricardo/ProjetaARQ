<ui:FluentWindow
    x:Class="ProjetaARQ.Commands.DebugFluentUi.DebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:ProjetaARQ.Core.UI.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjetaARQ.Commands.DebugFluentUi"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="DebugView"
    Width="800"
    Height="450"
    mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ProjetaARQ;component/Core/UI/DesignSystem.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>


    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,24"
            FontSize="24"
            FontWeight="SemiBold"
            Text="Auditoria de Injeção de Cores" />

        <StackPanel Grid.Row="1">

            <TextBlock
                Margin="0,0,0,8"
                FontWeight="Bold"
                Text="1. Cores Injetadas no Motor (Resultado do C#)" />
            <Border
                Margin="0,0,0,24"
                Padding="16"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8">
                <WrapPanel Orientation="Horizontal">

                    <Border
                        Width="120"
                        Height="90"
                        Margin="0,0,10,0"
                        Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Primary&#x0a;(Motor)"
                            TextAlignment="Center" />
                    </Border>

                    <Border
                        Width="120"
                        Height="90"
                        Margin="0,0,10,0"
                        Background="{DynamicResource SystemAccentColorSecondaryBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Secondary&#x0a;(Motor)"
                            TextAlignment="Center" />
                    </Border>

                    <Border
                        Width="120"
                        Height="90"
                        Margin="0,0,10,0"
                        Background="{DynamicResource SystemAccentColorTertiaryBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Tertiary&#x0a;(Motor)"
                            TextAlignment="Center" />
                    </Border>

                </WrapPanel>
            </Border>

            <TextBlock
                Margin="0,0,0,8"
                FontWeight="Bold"
                Text="2. Paleta Institucional Estática (Referência do XAML)" />
            <Border
                Padding="16"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8">
                <WrapPanel Orientation="Horizontal">

                    <Border
                        Width="90"
                        Height="90"
                        Margin="0,0,10,10"
                        Background="{StaticResource ProjetaRedBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Red" />
                    </Border>

                    <Border
                        Width="90"
                        Height="90"
                        Margin="0,0,10,10"
                        Background="{StaticResource ProjetaDarkRedBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Dark Red" />
                    </Border>

                    <Border
                        Width="90"
                        Height="90"
                        Margin="0,0,10,10"
                        Background="{StaticResource ProjetaBurgundyBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Burgundy" />
                    </Border>

                    <Border
                        Width="90"
                        Height="90"
                        Margin="0,0,10,10"
                        Background="{StaticResource ProjetaBlueBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Blue" />
                    </Border>

                    <Border
                        Width="90"
                        Height="90"
                        Margin="0,0,10,10"
                        Background="{StaticResource ProjetaTealBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Teal" />
                    </Border>

                    <Border
                        Width="90"
                        Height="90"
                        Margin="0,0,10,10"
                        Background="{StaticResource ProjetaGreenBrush}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="Green" />
                    </Border>

                </WrapPanel>
            </Border>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
