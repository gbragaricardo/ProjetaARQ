<ui:FluentWindow
    x:Class="ProjetaARQ.Commands.DetailDoor.DetailDoorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjetaARQ.Commands.DetailDoor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Width="450"
    Height="Auto"
    d:DataContext="{d:DesignInstance local:DetailDoorViewModel,
                                     IsDesignTimeCreatable=True}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  1. CARREGAMENTO BRUTO DO WPF-UI: Resolve o bug do Application.Current no XAML Designer  -->
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Theme/Light.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />

                <!--  2. PACK URI COMPLETO: Resolve o caminho do seu arquivo local  -->
                <ResourceDictionary Source="pack://application:,,,/ProjetaARQ;component/Core/UI/DesignSystem.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Border Padding="8,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Icon="/ProjetaARQ;component/Core/UI/Icons/logo.ico" />

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Padding="8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="1. Seleção de Fase" />

                        <ui:SymbolIcon
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Symbol="Info24">
                            <ui:SymbolIcon.ToolTip>
                                <ToolTip Content="Todas as portas da fase escolhidas serão detalhadas." />
                            </ui:SymbolIcon.ToolTip>
                        </ui:SymbolIcon>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="8">
                    <ComboBox
                        IsEditable="True"
                        IsReadOnly="True"
                        Text="Selecione a Fase" />
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Padding="8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="2. Seleção de vistas" />

                        <ui:SymbolIcon
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Symbol="Info24">
                            <ui:SymbolIcon.ToolTip>
                                <ToolTip Content="Marque quais vistas serão geradas para as montagens." />
                            </ui:SymbolIcon.ToolTip>
                        </ui:SymbolIcon>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Padding="8">
                    <ItemsControl ItemsSource="{Binding ViewOptionItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid VerticalAlignment="Top" Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ViewOptionItem}">
                                <StackPanel>

                                    <CheckBox
                                        Padding="0"
                                        Content="{Binding}"
                                        IsChecked="{Binding IsSelected}" />

                                    <ComboBox
                                        Margin="0,0,0,16"
                                        IsEditable="True"
                                        IsEnabled="{Binding IsSelected}"
                                        IsReadOnly="True"
                                        SelectedItem="{Binding SelectedTemplate}"
                                        Text="Select a Template" />

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </Border>
            </Grid>

            <ui:Button
                Grid.Row="3"
                Margin="8"
                Padding="8"
                HorizontalAlignment="Right"
                Content="Gerar Montagens" />
        </Grid>
    </Border>
</ui:FluentWindow>
