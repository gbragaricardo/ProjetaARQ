<UserControl
    x:Class="ProjetaARQ.Commands.WordExport.MVVM.Views.RuleCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:local="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.Views"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.ViewModels"
    Height="Auto"
    d:DataContext="{d:DesignInstance viewModel:RuleCardViewModel}"
    d:DesignHeight="120"
    d:DesignWidth="450"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary Source="/ProjetaARQ;component/Commands/WordExport/MVVM/Resources/DataTemplates.xaml" />
    </UserControl.Resources>

    <Expander
        Padding="0"
        HorizontalAlignment="Stretch"
        mah:HeaderedControlHelper.HeaderBackground="{DynamicResource MahApps.Brushes.Accent}"
        BorderBrush="Black"
        BorderThickness="0,0,0,1"
        IsExpanded="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        Style="{DynamicResource MahApps.Styles.Expander}">

        <Expander.Header>

            <Border>
                <StackPanel Height="50" Orientation="Horizontal">

                    <TextBox
                        Height="26"
                        MinWidth="200"
                        MaxWidth="400"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsUndoEnabled="False"
                        Text="{Binding RuleCardName, Mode=TwoWay}" />

                    <ComboBox
                        Height="26"
                        MinWidth="200"
                        MaxWidth="400"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        mah:TextBoxHelper.Watermark="Selecione a ação"
                        BorderBrush="Black"
                        ItemsSource="{Binding Source={StaticResource RuleActionTypeProvider}}"
                        SelectedIndex="-1"
                        SelectedValue="{Binding SelectedAction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock mah:TextBoxHelper.Watermark="TESTE" Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>


                </StackPanel>
            </Border>

        </Expander.Header>

        <ContentControl Content="{Binding CurrentActionViewModel}" />

        <!--<Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="20">
                <TextBlock Text="Controles para configurar a regra..." HorizontalAlignment="Left"/>
            </Grid>

            <Thumb dd:DragDrop.DragSourceIgnore="True"
                   Grid.Row="1"
                   Height="10"
                   Cursor="SizeNS"
                   Background="LightGray"
                   Opacity="0.7"
                   DragDelta="Thumb_DragDelta"/>
        </Grid>-->
    </Expander>
</UserControl>