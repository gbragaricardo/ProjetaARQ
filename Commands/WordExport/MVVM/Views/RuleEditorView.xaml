<UserControl
    x:Class="ProjetaARQ.Commands.WordExport.MVVM.Views.RuleEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ProjetaARQ.UI.Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.Views"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.ViewModels"
    d:DataContext="{d:DesignInstance viewModel:RuleEditorViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="780"
    d:DesignWidth="740"
    Background="Transparent"
    mc:Ignorable="d">


    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ProjetaARQ;component/Commands/WordExport/MVVM/Resources/DataTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibleConverter x:Key="BoolToVisible" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1">
            <ItemsControl
                dd:DragDrop.DragHandler="{Binding RuleDragHandler}"
                dd:DragDrop.DropHandler="{Binding RuleDropHandler}"
                dd:DragDrop.IsDragSource="True"
                dd:DragDrop.IsDropTarget="True"
                dd:DragDrop.UseDefaultDragAdorner="True"
                ItemsSource="{Binding RuleCardList}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:RuleCard Margin="10" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <Border
            Grid.Row="0"
            Padding="10"
            dd:DragDrop.DropHandler="{Binding DeleteDropHandler}"
            dd:DragDrop.IsDropTarget="True"
            AllowDrop="True"
            Background="Transparent"
            Visibility="{Binding RuleDragHandler.AddBorder, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVisible}}">

            <StackPanel Orientation="Horizontal">

                <Border>
                    <Button Command="{Binding AddRuleCommand}" Style="{StaticResource MahApps.Styles.Button.Chromeless}">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterialDesign Margin="0,0,5,0" Kind="Add" />
                            <TextBlock VerticalAlignment="Center" Text="ADICIONAR REGRA" />
                        </StackPanel>
                    </Button>
                </Border>

                <Border Margin="15,0">
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource MahApps.Styles.Button.Chromeless}">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Margin="0,0,5,0" Kind="ContentSave" />
                            <TextBlock VerticalAlignment="Center" Text="SALVAR" />
                        </StackPanel>
                    </Button>
                </Border>

                <Border Margin="15,0">
                    <Button Command="{Binding ExportCommand}" Style="{StaticResource MahApps.Styles.Button.Chromeless}">

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Margin="0,0,5,0" Kind="FileWord" />
                            <TextBlock VerticalAlignment="Center" Text="EXPORTAR TESTE" />
                        </StackPanel>
                    </Button>
                </Border>

            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            dd:DragDrop.DropHandler="{Binding DeleteDropHandler}"
            dd:DragDrop.IsDropTarget="True"
            AllowDrop="True"
            Background="{DynamicResource MahApps.Brushes.Accent}"
            Visibility="{Binding RuleDragHandler.DeleteBorder, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVisible}}">

            <StackPanel Opacity="0.5" Orientation="Horizontal">
                <iconPacks:PackIconMaterial
                    Margin="10,0,10,0"
                    VerticalAlignment="Center"
                    Kind="TrashCanOutline" />
                <TextBlock VerticalAlignment="Center" Text="ARRASTE AQUI PARA APAGAR A REGRA" />
            </StackPanel>
        </Border>


    </Grid>
</UserControl>
