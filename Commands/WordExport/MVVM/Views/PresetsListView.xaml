<UserControl
    x:Class="ProjetaARQ.Commands.WordExport.MVVM.Views.PresetsListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ProjetaARQ.UI.Core.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.Views"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.ViewModels"
    x:Name="PresetListView_UserControl"
    d:DataContext="{d:DesignInstance viewModel:PresetsListViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ProjetaARQ;component/Commands/WordExport/MVVM/Resources/DataTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Padding="32,16,0,32" Background="Transparent">

        <ListView
            x:Name="PresetsList_ListView"
            Padding="0,0,32,0"
            HorizontalAlignment="Stretch"
            AlternationCount="2"
            ItemContainerStyle="{StaticResource PresetsListViewItemStyle}"
            ItemsSource="{Binding PresetsList}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource PresetListViewHeaderStyle}">

                    <GridViewColumn Width="{Binding ActualWidth, ElementName=PresetsList_ListView, Converter={StaticResource PercentageConverter}, ConverterParameter=60}" Header="Nome">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,15" Orientation="Horizontal">


                                    <Image
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,5,0"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='word-doc.png'}" />

                                    <TextBlock
                                        Padding="0,0,50,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding PresetName}" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="{Binding ActualWidth, ElementName=PresetsList_ListView, Converter={StaticResource PercentageConverter}, ConverterParameter=20}" Header="Data de Modificação">

                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <!--<TextBlock Text="{Binding LastModified, StringFormat='dd/MM/yyyy'}" VerticalAlignment="Center"/>-->
                                <TextBlock Text="22/05/2001" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="{Binding ActualWidth, ElementName=PresetsList_ListView, Converter={StaticResource PercentageConverter}, ConverterParameter=20}" Header="Opções">

                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel
                                    x:Name="ListItemOption"
                                    DockPanel.Dock="Right"
                                    Orientation="Horizontal">

                                    <Button
                                        Margin="0,0,16,0"
                                        Command="{Binding DataContext.EditPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding .}"
                                        Cursor="Hand"
                                        FontSize="20"
                                        Foreground="Black"
                                        Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                                        ToolTip="Editar Preset">

                                        <iconPacks:PackIconMaterialDesign Kind="ModeEditOutlineOutline" />
                                    </Button>

                                    <Button
                                        Margin="0,0,16,0"
                                        Cursor="Hand"
                                        Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                                        ToolTip="Duplicar Preset">
                                        <iconPacks:PackIconMaterial Kind="ContentCopy" />
                                    </Button>

                                    <Button
                                        Margin="0,0,16,0"
                                        Cursor="Hand"
                                        Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                                        ToolTip="Renomear Preset">
                                        <iconPacks:PackIconMaterial Kind="FormTextBox" />
                                    </Button>

                                    <Button
                                        Margin="0,0,0,0"
                                        Cursor="Hand"
                                        Style="{DynamicResource MahApps.Styles.Button.Chromeless}"
                                        ToolTip="Deletar Preset">
                                        <iconPacks:PackIconMaterialDesign Kind="DeleteOutlineOutline" />
                                    </Button>

                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Border>
</UserControl>
