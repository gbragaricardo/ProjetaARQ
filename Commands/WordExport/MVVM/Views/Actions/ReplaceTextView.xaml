<UserControl
    x:Class="ProjetaARQ.Commands.WordExport.MVVM.Views.Actions.ReplaceTextView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:actionViewModel="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.ViewModels.Actions"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.Views.Actions"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:ProjetaARQ.Commands.WordExport.MVVM.ViewModels"
    d:DataContext="{d:DesignInstance actionViewModel:ReplaceTextViewModel}"
    d:DesignWidth="800"
    Background="#FFFEFEFE"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ProjetaARQ;component/Commands/WordExport/MVVM/Resources/DataTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style BasedOn="{StaticResource MahApps.Styles.ComboBox}" TargetType="ComboBox">
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style BasedOn="{StaticResource MahApps.Styles.Button}" TargetType="Button">
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style BasedOn="{StaticResource MahApps.Styles.Label}" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border>
        <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="90" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="2"
                Grid.RowSpan="3"
                Grid.ColumnSpan="2"
                Width="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                BorderBrush="Black"
                BorderThickness="2" />

            <Border
                Grid.Row="0"
                Grid.Column="0"
                Padding="20,10">

                <StackPanel>

                    <Label Content="CONDIÇÃO:" />
                    <ComboBox
                        Height="Auto"
                        VerticalContentAlignment="Center"
                        FontSize="14"
                        ItemsSource="{Binding Source={StaticResource ConditionTypeProvider}}"
                        PreviewMouseWheel="ComboBox_PreviewMouseWheel"
                        SelectedIndex="-1"
                        SelectedItem="{Binding SelectedCondition, Mode=TwoWay}">

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

            </Border>

            <Border
                Grid.Row="0"
                Grid.Column="1"
                Padding="20,10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <CheckBox
                        Grid.ColumnSpan="2"
                        Height="Auto"
                        Margin="0,15,0,0"
                        mah:CheckBoxHelper.CheckSize="30"
                        mah:VisibilityHelper.IsCollapsed="{Binding IsCheckBoxConditionCollapsed}">

                        <TextBox
                            VerticalContentAlignment="Center"
                            mah:TextBoxHelper.Watermark="Digite a condição para o usuário"
                            FontSize="14"
                            Text="{Binding CheckBoxConditionText}" />
                    </CheckBox>
                </Grid>

            </Border>


            <Border
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Height="50"
                Visibility="Collapsed">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    FontSize="14">
                    <TextBlock.Text>
                        ESPAÇO DE LOGICA DE CONDICAO POSSIVEL DE IMPLEMENTAR
                    </TextBlock.Text>
                </TextBlock>
            </Border>

            <Border
                Grid.Row="2"
                Grid.Column="0"
                Padding="20,10"
                BorderBrush="Black"
                BorderThickness="0,1,0,0">

                <StackPanel>

                    <Border Name="TargetSection" Margin="0,0,0,10">
                        <StackPanel Orientation="Vertical">

                            <Label Content="TAG DO CONTEÚDO:" />

                            <TextBox
                                Padding="5,0,0,0"
                                VerticalContentAlignment="Center"
                                mah:TextBoxHelper.Watermark="Digite o nome da Tag"
                                FontSize="14"
                                Text="{Binding ContentTag}" />

                            <Separator
                                Width="Auto"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <Border Name="EditMode" Margin="0,0,0,10">

                        <StackPanel Orientation="Vertical">

                            <Label Content="MODO:" />

                            <ComboBox
                                Padding="5,0,0,0"
                                mah:ComboBoxHelper.CharacterCasing="Upper"
                                ItemsSource="{Binding Source={StaticResource ReplaceTextModeTypeProvider}}"
                                PreviewMouseWheel="ComboBox_PreviewMouseWheel"
                                SelectedIndex="0"
                                SelectedItem="{Binding SelectedEditMode, Mode=TwoWay}">

                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Separator
                                Width="Auto"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <Border mah:VisibilityHelper.IsCollapsed="{Binding IsTextToReplaceCollapsed}">
                        <StackPanel Orientation="Vertical">
                            <Label Content="TEXTO A SER SUBSTITUIDO:" />
                            <mah:ClipBorder
                                MinHeight="100"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                CornerRadius="5">


                                <TextBox
                                    Width="Auto"
                                    AcceptsReturn="True"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Text="{Binding TextBoxToReplace}"
                                    TextWrapping="Wrap">
                                    <mah:TextBoxHelper.Watermark>
                                        Digite o texto a ser substituído
                                    </mah:TextBoxHelper.Watermark>
                                </TextBox>

                            </mah:ClipBorder>
                        </StackPanel>
                    </Border>


                </StackPanel>


            </Border>

            <Border
                Grid.Row="2"
                Grid.Column="1"
                Padding="20,10"
                BorderBrush="Black"
                BorderThickness="0,1,0,0">

                <StackPanel>

                    <Border Name="DataSource" Margin="0,0,0,10">
                        <StackPanel Orientation="Vertical">

                            <Label Content="MODO DE INSERÇÃO:" />

                            <ComboBox
                                Padding="5,0,0,0"
                                mah:TextBoxHelper.Watermark="TESTE"
                                IsEnabled="{Binding IsDataSourceEnabled}"
                                ItemsSource="{Binding Source={StaticResource DataSourceTypeProvider}}"
                                SelectedIndex="0"
                                SelectedItem="{Binding SelectedDataSource, Mode=TwoWay}">

                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumToDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Separator
                                Width="Auto"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <Border
                        Name="TextBlockOptions"
                        Margin="0,0,0,10"
                        mah:VisibilityHelper.IsCollapsed="{Binding IsTextBlockOptionsCollapsed}">
                        <StackPanel Orientation="Vertical">

                            <Label Content="BLOCO DE TEXTO:" />

                            <ComboBox Padding="5,0,0,0" SelectedIndex="0">

                                <ComboBoxItem Content="DESCRIÇÃO URBANISMO" />
                            </ComboBox>

                            <Separator
                                Width="Auto"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <Border
                        Name="ParameterName"
                        Margin="0,0,0,10"
                        mah:VisibilityHelper.IsCollapsed="{Binding IsSetRevitPararameterCollapsed}">
                        <StackPanel Orientation="Vertical">

                            <Label Content="PARÂMETRO:" />

                            <ComboBox
                                Padding="5,0,0,0"
                                mah:TextBoxHelper.Watermark="Digite o nome do parâmetro"
                                IsEditable="True"
                                PreviewMouseWheel="ComboBox_PreviewMouseWheel"
                                SelectedIndex="0"
                                Text="{Binding RevitParameterName, Mode=TwoWay}" />

                            <Separator
                                Width="Auto"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>


                    <Border x:Name="NewTextInputBox" mah:VisibilityHelper.IsCollapsed="{Binding IsNewTextCollapsed}">

                        <StackPanel Orientation="Vertical">
                            <Label Content="TEXTO NOVO:" />
                            <mah:ClipBorder
                                MinHeight="100"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                CornerRadius="5">


                                <TextBox
                                    Width="Auto"
                                    AcceptsReturn="True"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Text="{Binding ReplacementTextBox}"
                                    TextWrapping="Wrap">

                                    <mah:TextBoxHelper.Watermark>
                                        Digite o novo texto
                                    </mah:TextBoxHelper.Watermark>
                                </TextBox>

                            </mah:ClipBorder>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>
