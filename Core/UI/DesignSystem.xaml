<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />
        <ui:ControlsDictionary />
    </ResourceDictionary.MergedDictionaries>

    <Color x:Key="SystemAccentColorPrimary">#DB0F19</Color>
    <Color x:Key="SystemAccentColorSecondary">#A50B13</Color>
    <Color x:Key="SystemAccentColorTertiary">#4C0105</Color>
    <Color x:Key="ProjetaBlue">#16559F</Color>
    <Color x:Key="ProjetaTeal">#009587</Color>
    <Color x:Key="ProjetaGreen">#26994C</Color>
    <Color x:Key="ProjetaCopper">#B17F49</Color>
    <Color x:Key="ProjetaGray">#828282</Color>
    <Color x:Key="ProjetaBlack">#000000</Color>


    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource SystemAccentColorPrimary}" />
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource SystemAccentColorSecondary}" />
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="{StaticResource SystemAccentColorTertiary}" />
    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="{StaticResource SystemAccentColorPrimary}" />
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="White" />
    <SolidColorBrush x:Key="ProjetaRedBrush" Color="{StaticResource SystemAccentColorPrimary}" />
    <SolidColorBrush x:Key="ProjetaDarkRedBrush" Color="{StaticResource SystemAccentColorSecondary}" />
    <SolidColorBrush x:Key="ProjetaBurgundyBrush" Color="{StaticResource SystemAccentColorTertiary}" />

    <SolidColorBrush x:Key="ProjetaBlueBrush" Color="{StaticResource ProjetaBlue}" />
    <SolidColorBrush x:Key="ProjetaTealBrush" Color="{StaticResource ProjetaTeal}" />
    <SolidColorBrush x:Key="ProjetaGreenBrush" Color="{StaticResource ProjetaGreen}" />
    <SolidColorBrush x:Key="ProjetaCopperBrush" Color="{StaticResource ProjetaCopper}" />
    <SolidColorBrush x:Key="ProjetaGrayBrush" Color="{StaticResource ProjetaGray}" />
    <SolidColorBrush x:Key="ProjetaBlackBrush" Color="{StaticResource ProjetaBlack}" />

    <Style x:Key="ProjetaPrimaryButtonStyle" TargetType="ui:Button">
        <Setter Property="Background" Value="{StaticResource ProjetaRedBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ui:Button">
                    <Border
                        x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">

                        <StackPanel
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">

                            <ContentPresenter
                                x:Name="IconPresenter"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Icon}" />

                            <ContentPresenter
                                x:Name="TextPresenter"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}" />
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource ProjetaDarkRedBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource ProjetaBurgundyBrush}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>